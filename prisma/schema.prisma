// auditresto360 — schéma Prisma.
// IMPORTANT : auditresto360 écrit dans la MÊME base Supabase qu'audithygiène
// (CRM et application mutualisés). Ce modèle Lead est un SOUS-ENSEMBLE de la table
// "leads" existante d'audithygiène : il ne déclare que les colonnes que le site
// renseigne. Les autres colonnes utilisent leurs valeurs par défaut côté base.
//
// NE JAMAIS lancer `prisma migrate` ni `prisma db push` depuis ce projet :
// la base est gérée par le projet audithygiène. Ici on fait uniquement
// `prisma generate` (client) et des INSERT.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Sous-ensemble de la table "leads" (gérée par audithygiène).
model Lead {
  id        String  @id @default(cuid())
  nom       String
  email     String
  telephone String?
  ville     String?
  codePostal String?
  message   String?
  source    String? // configurateur, contact, ... (préfixé resto360)

  consentementRGPD      Boolean   @default(false)
  consentementAt        DateTime?
  consentementMarketing Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("leads")
}
