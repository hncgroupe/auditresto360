# auditresto360 — variables d'environnement (placeholders).
# Copier en .env.local (jamais commité) et renseigner les vraies valeurs.

# URL publique du site
NEXT_PUBLIC_SITE_URL=https://auditresto360.fr

# Base de données Postgres (Supabase recommandé) — propre à auditresto360
DATABASE_URL=

# Notifications Telegram (bot + chat dédiés auditresto360)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email transactionnel Brevo
BREVO_API_KEY=
BREVO_SENDER_EMAIL=contact@auditresto360.fr
BREVO_SENDER_NAME=auditresto360

# Vérification moteurs de recherche
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=
